# --- Required (the panel REFUSES TO START on empty/default secrets) ---

# Admin account: initial login for the panel (JWT + optional 2FA).
# The password here is only the INITIAL one — change it later in the UI (🔑),
# which also invalidates old sessions. It is NOT re-synced on restart.
ACONTROL_ADMIN_USER=admin
# Set a strong password (not "admin"/"changeme"), else the panel won't start:
ACONTROL_ADMIN_PASSWORD=

# JWT signing secret — MUST be 32+ random chars. Generate with:
#   openssl rand -hex 32
# A weak/empty/default value makes admin tokens forgeable, so the panel
# refuses to start unless this is strong.
ACONTROL_JWT_SECRET=

# PostgreSQL password (used only inside the compose network). Set any strong
# random value; postgres won't initialise without it.
ACONTROL_DB_PASSWORD=

# Break-glass recovery: set to 1 to reset the admin password (to
# ACONTROL_ADMIN_PASSWORD) and disable 2FA on next start — use only if you lost
# both the password and 2FA, then set back to 0 and restart. Leave 0 normally.
ACONTROL_ADMIN_PASSWORD_RESET=0

# Public IP of the panel — written into node setup scripts (ufw / hosts.allow)
ACONTROL_PANEL_IP=

# Where the panel is published on the host (standalone / base compose).
# Default binds to localhost — put a reverse proxy with HTTPS in front.
# Set to e.g. 0.0.0.0:8080 to expose on all interfaces (plain HTTP — be careful).
ACONTROL_BIND=127.0.0.1:8080

# Image tag used when installing from prebuilt GHCR images (docker compose pull).
# "latest" = newest release; pin an exact version (e.g. 0.40.2) for reproducible
# deploys. Ignored when you build from source (docker compose up --build).
ACONTROL_VERSION=latest

# --- Edge TLS (compose.tls.yml self-contained Caddy, or compose.caddy.yml) ---

# Domain the panel is served on (edge TLS). No domain of your own? Use a free
# sslip.io name that resolves to your server's IP — dashes for dots, e.g. for
# 203.0.113.10 use:  203-0-113-10.sslip.io
ACONTROL_DOMAIN=panel.example.com

# Space-separated IPs/CIDRs allowed to reach the panel (edge IP allow-list).
# EMPTY = open to everyone (guarded only by login + 2FA) — this is the default
# so anyone can bring it up. Set your own IP(s)/CIDR(s) to lock it down, e.g.
#   ACONTROL_ALLOW_IPS=203.0.113.10 198.51.100.0/24
ACONTROL_ALLOW_IPS=

# Only for compose.caddy.yml (external caddy-docker-proxy): the Docker network
# your caddy-docker-proxy watches (docker inspect <caddy> -f '{{json .NetworkSettings.Networks}}')
ACONTROL_CADDY_NETWORK=caddy

# --- Optional (defaults shown) ---

# Default SSH user prefilled in the "add server" form
ACONTROL_DEFAULT_SSH_USER=acontrol

# Metrics/monitoring collection interval, seconds (0 = off)
ACONTROL_STATS_INTERVAL=300

# Expired-client auto-revoke scan interval, seconds (0 = off)
ACONTROL_EXPIRY_INTERVAL=300

# Low-disk alert threshold, percent (0 = off)
ACONTROL_DISK_ALERT_PERCENT=90

# Auto-backup: interval in hours (0 = off) and how many copies to keep
ACONTROL_BACKUP_INTERVAL_HOURS=24
ACONTROL_BACKUP_KEEP=14
