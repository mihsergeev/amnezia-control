# --- Required ---

# Admin account: login for the panel (JWT) and basic-auth at the edge
ACONTROL_ADMIN_USER=admin
ACONTROL_ADMIN_PASSWORD=changeme

# PostgreSQL password (used only inside the compose network)
ACONTROL_DB_PASSWORD=changeme

# JWT signing secret — 32+ random bytes (e.g. `openssl rand -hex 32`)
ACONTROL_JWT_SECRET=changeme

# Public IP of the panel — written into node setup scripts (ufw / hosts.allow)
ACONTROL_PANEL_IP=

# Domain served by the bundled caddy-docker-proxy (edge TLS)
ACONTROL_DOMAIN=panel.example.com

# Space-separated IPs allowed to reach the panel (edge IP allow-list).
# Set to your admin IPs. To disable allow-listing, remove the @denied/abort
# labels from the frontend service in docker-compose.yml.
ACONTROL_ALLOW_IPS=203.0.113.10 198.51.100.23

# --- Optional (defaults shown) ---

# Default SSH user prefilled in the "add server" form
ACONTROL_DEFAULT_SSH_USER=acontrol

# Metrics/monitoring collection interval, seconds (0 = off)
ACONTROL_STATS_INTERVAL=300

# Expired-client auto-revoke scan interval, seconds (0 = off)
ACONTROL_EXPIRY_INTERVAL=300

# Low-disk alert threshold, percent (0 = off)
ACONTROL_DISK_ALERT_PERCENT=90

# Auto-backup: interval in hours (0 = off) and how many copies to keep
ACONTROL_BACKUP_INTERVAL_HOURS=24
ACONTROL_BACKUP_KEEP=14
